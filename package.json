{
  "name": "backend-chatbot",
  "version": "1.0.0",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon --watch . --ext js,ts --exec tsx app.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:backend": "tsc",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "start:backend": "node dist/app.js",
    "start:frontend": "npm run start --prefix frontend",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "postinstall": "patch-package",
    "prepare": "husky",
    "lint": "eslint . --ext .js,.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.1",
    "@langchain/community": "^0.3.40",
    "@langchain/core": "^0.3.51",
    "@langchain/langgraph": "^0.2.68",
    "@langchain/langgraph-checkpoint-mongodb": "^0.0.6",
    "@langchain/mongodb": "^0.1.0",
    "@langchain/openai": "^0.5.5",
    "@langchain/textsplitters": "^0.1.0",
    "@whthduck/slugify-vi": "^0.0.9",
    "automapper-ts": "^1.9.0",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "cron": "^4.3.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "html-to-text": "^9.0.5",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.24",
    "mongoose": "^8.14.1",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^4.0.5",
    "nodemailer": "^6.10.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "redis": "^5.5.6",
    "replicate": "^1.0.1",
    "sanitize-html": "^2.15.0",
    "sharp": "^0.34.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.9",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "author": "",
  "license": "ISC",
  "description": ""
}
